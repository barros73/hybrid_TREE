{
  "name": "hybrid-tree",
  "displayName": "Hybrid Tree",
  "description": "An AI-driven Project Orchestrator Plugin for VS Code and Antigravity IDE",
  "version": "0.6.1",
  "bin": {
    "hybrid-tree": "./dist/cli.js"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "publisher": "barros73",
  "repository": {
    "type": "git",
    "url": "https://github.com/barros73/hybrid-TREE"
  },
  "categories": [
    "Other"
  ],
  "license": "Apache-2.0",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hybridTree.init",
        "title": "Hybrid Tree: Initialize"
      },
      {
        "command": "hybridTree.toggleState",
        "title": "Toggle State",
        "icon": "$(sync)"
      },
      {
        "command": "hybridTree.copyContext",
        "title": "Hybrid Tree: Copy AI Context",
        "icon": "$(clippy)"
      },
      {
        "command": "hybridTree.suggestNextStep",
        "title": "Hybrid Tree: Suggest Next Step",
        "icon": "$(lightbulb)"
      },
      {
        "command": "hybridTree.exportJson",
        "title": "Hybrid Tree: Export JSON State",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "hybridTree.toggleState",
          "when": "view == hybridTree",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hybrid-tree-explorer",
          "title": "Hybrid Tree",
          "icon": "$(list-tree)"
        }
      ]
    },
    "views": {
      "hybrid-tree-explorer": [
        {
          "id": "hybridTree",
          "name": "Project Tree",
          "icon": "$(list-tree)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run build && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}